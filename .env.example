# ── Supabase ───────────────────────────────────────────────────────────────
# Tableau de bord Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé service_role : SERVEUR UNIQUEMENT, jamais exposée au client.
SUPABASE_SERVICE_ROLE_KEY=

# ── Resend (emails transactionnels) ─────────────────────────────────────────
# Tableau de bord Resend → API Keys
RESEND_API_KEY=
# Adresse expéditrice (nécessite un domaine vérifié dans Resend).
# Laisser vide → utilise onboarding@resend.dev (tests uniquement, vers son propre email).
EMAIL_FROM=

# ── Bunny Stream (vidéos — branché plus tard) ────────────────────────────────
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_CDN_HOSTNAME=

# ── Revolut (paiement — branché plus tard) ───────────────────────────────────
# Revolut Business API (b2b.revolut.com) — gestion du compte professionnel
REVOLUT_API_KEY=
# Revolut Merchant API (merchant.revolut.com) — encaissement des élèves
# Dashboard Revolut Business → Settings → Merchant API → API Keys
REVOLUT_MERCHANT_API_KEY=
# Secret webhook : Dashboard Revolut Merchant → Webhooks → ton endpoint
REVOLUT_WEBHOOK_SECRET=

# ── Zoom (visio — branché plus tard) ─────────────────────────────────────────
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
